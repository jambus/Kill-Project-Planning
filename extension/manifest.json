{
  "manifest_version": 3,
  "name": "Intelligent Resource Planner",
  "version": "1.0.0",
  "description": "Intelligent Resource Planner which help project manager and Engineer manager to plan the resources easily even business priority change",
  "key": "",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "*://*.atlassian.net/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts"
  },
  "content_scripts": [
    {
      "matches": ["*://*.atlassian.net/browse/*"],
      "js": ["src/content/index.tsx"]
    }
  ],
  "options_page": "src/options/index.html",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  },
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
